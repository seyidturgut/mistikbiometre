# xAI / Grok configuration. Required for AI-generated readings.
# Without these, the app falls back to local combinatorial readings.

# Get a key at https://console.x.ai (and add credits to your team)
XAI_API_KEY=

# Optional — defaults to grok-2-1212 if unset.
# Examples: grok-3, grok-3-mini, grok-2-1212
XAI_MODEL=grok-2-1212
